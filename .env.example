# Server-only — never NEXT_PUBLIC_ (PRD §6).
# Ask for a SEPARATE Resend API key named `hangout-landing` (same account
# sends the app's auth emails; separate keys can be revoked independently).
# Needs FULL ACCESS permission (the waitlist writes contacts to an Audience).
RESEND_API_KEY=

# Audiences → your audience → the UUID shown on its page.
RESEND_AUDIENCE_ID=

# Where "Say hello" messages are delivered.
# SANDBOX NOTE: until hang-out.app is verified in Resend, delivery only
# works to the email address you signed up to Resend with — use that here
# while testing, then switch to hello@hang-out.app.
CONTACT_TO=hello@hang-out.app

# Sender for "Say hello" messages. Leave unset in production
# (defaults to "hang:out <no-reply@hang-out.app>").
# SANDBOX NOTE: until the domain is verified, Resend only allows sending
# from onboarding@resend.dev — uncomment for local testing:
# RESEND_FROM=onboarding@resend.dev

# Build-time flag: "true" swaps the waitlist CTA for the Play Store badge.
NEXT_PUBLIC_LAUNCHED=
